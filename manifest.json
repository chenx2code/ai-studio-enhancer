{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.1.8",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "clipboardWrite",
    "storage",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://aistudio.google.com/*"],
      "run_at": "document_start",
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"], 
      "matches": ["https://aistudio.google.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}